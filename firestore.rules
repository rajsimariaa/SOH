rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Check if the user has an admin role in their document
    function isAdmin() {
      let isSuperAdmin = request.auth.token.email in ['rajsimariaa@gmail.com', 'krutika3011@gmail.com'];
      return isSignedIn() && (isSuperAdmin || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collections ---

    // Users Collection: Everyone can see their own, admins see all, and users can see organizations.
    match /users/{userId} {
      allow read: if isSignedIn() && (
        isOwner(userId) || 
        isAdmin() || 
        resource.data.role == 'organization'
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Requests Collection: User who requested, Org who provides, and Admins can access.
    match /requests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.orgId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.orgId == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Chats Collection: Participants and Admins can access.
    match /chats/{chatId} {
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.participants || 
        isAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.participants || 
        isAdmin()
      );
      allow delete: if isAdmin();
      
      // Messages Sub-collection
      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || 
          isAdmin()
        );
        allow create: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        );
        allow update, delete: if isAdmin();
      }
    }

    // Grievances Collection
    match /grievances/{grievanceId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // News Collection: Publicly readable, only Admins can write.
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
